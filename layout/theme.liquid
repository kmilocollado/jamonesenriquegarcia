  {% if request.design_mode %}<script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>{% endif %}

  {% if settings.animations_enabled %}
    {{ 'animate.min.css' | asset_url | stylesheet_tag }}
  {% endif %}

  {% if settings.popup--enable or settings.popup--test-mode %}
    {{ 'component-popup.min.css' | asset_url | stylesheet_tag }}
  {% endif %}

  {% if settings.enable_verification_popup or settings.verification-pop-up__test-mode %}
    {{ 'component-verification-popup.min.css' | asset_url | stylesheet_tag }}
  {% endif %}

  {% if request.design_mode %}
    <script type="application/json" id="theme-analytics">
      {
        "shop_email": {{ shop.email | json }},
        "shop_name": {{ shop.name | json }},
        "shop_url": {{ shop.url | json }}
      }
    </script>
    {% # theme-check-disable RemoteAsset %}
    <script src="https://themes.weareeight.workers.dev/analytics.js" type="module"></script>
    {% # theme-check-enable RemoteAsset %}
  {% endif %}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var extraRules = window.extraRules || {};
  
      function replaceH2WithP(el) {
        if (!el || el.tagName.toLowerCase() === 'p') return;
        var p = document.createElement('p');
        p.innerHTML = el.innerHTML;
        Array.prototype.slice.call(el.attributes).forEach(function(attr) {
          p.setAttribute(attr.name, attr.value);
        });
        el.parentNode.replaceChild(p, el);
      }
  
      function scanAndReplace() {
        var banner = document.getElementById('shopify-pc__banner__body-title');
        replaceH2WithP(banner);
  
        Object.keys(extraRules).forEach(function(sel) {
          document.querySelectorAll(sel).forEach(function(node) {
            replaceH2WithP(node);
          });
        });
      }
      scanAndReplace();
  
      var observer = new MutationObserver(function(muts) {
        muts.forEach(function(m) {
          m.addedNodes.forEach(function(node) {
            if (node.nodeType !== 1) return;
            if (node.id === 'shopify-pc__banner__body-title') {
              replaceH2WithP(node);
            } else {
              var found = node.querySelector('#shopify-pc__banner__body-title');
              replaceH2WithP(found);
            }
            Object.keys(extraRules).forEach(function(sel) {
              if (node.matches && node.matches(sel)) {
                replaceH2WithP(node);
              }
              var inside = node.querySelector(sel);
              replaceH2WithP(inside);
            });
          });
        });
      });
      observer.observe(document.body, { childList: true, subtree: true });
    });
  </script>
  <script>
      (function () {
        var overlay = document.getElementById('cookie-consent-overlay');
        if (!overlay) return;

        var consentFinalized = false;
        var overlayShown = false;
        var moRafScheduled = false;

        function setOverlay(shouldShow) {
          if (consentFinalized) shouldShow = false;

          if (shouldShow === overlayShown) return;

          overlayShown = shouldShow;
          if (overlayShown) {
            overlay.style.display = 'block';
            document.documentElement.classList.add('cookie-consent-lock');
            document.body.classList.add('cookie-consent-lock');
            try {
              document.getElementById('MainContent')?.setAttribute('inert', '');
            } catch (e) {}
          } else {
            overlay.style.display = 'none';
            document.documentElement.classList.remove('cookie-consent-lock');
            document.body.classList.remove('cookie-consent-lock');
            try {
              document.getElementById('MainContent')?.removeAttribute('inert');
            } catch (e) {}
          }
        }

        function bannerVisible() {
          var b = document.getElementById('shopify-pc__banner');
          if (!b) return false;
          var s = window.getComputedStyle(b);
          return s.display !== 'none' && s.visibility !== 'hidden' && s.opacity !== '0';
        }

        function prefsVisible() {
          var d = document.querySelector(
            '.shopify-pc__prefs__dialog, .shopify-policy__dialog, .shopify-pc__banner__dialog'
          );
          if (!d) return false;
          var s = window.getComputedStyle(d);
          return s.display !== 'none' && s.visibility !== 'hidden' && s.opacity !== '0';
        }

        function decisionKnown(prefs) {
          return (
            typeof prefs?.analytics !== 'undefined' ||
            typeof prefs?.marketing !== 'undefined' ||
            typeof prefs?.preferences !== 'undefined'
          );
        }

        function recompute() {
          if (consentFinalized) {
            setOverlay(false);
            return;
          }
          setOverlay(bannerVisible() || prefsVisible());
        }

        function updateFromConsentState() {
          if (!window.Shopify?.customerPrivacy?.getConsent) {
            recompute();
            return Promise.resolve();
          }
          return window.Shopify.customerPrivacy
            .getConsent()
            .then(function (state) {
              var p = state?.consent_preferences || state || {};
              consentFinalized = decisionKnown(p);
              recompute();
            })
            .catch(function () {
              recompute();
            });
        }

        function handleInitial() {
          var TIMEOUT_MS = 8000;
          var timeout = setTimeout(function () {
            consentFinalized && setOverlay(false);
          }, TIMEOUT_MS);
          updateFromConsentState().finally(function () {
            clearTimeout(timeout);
          });
        }

        document.addEventListener('shopify:consent:changed', function () {
          consentFinalized = true;
          setOverlay(false);
        });

        document.addEventListener(
          'click',
          function (e) {
            var btn =
              e.target &&
              e.target.closest(
                '#shopify-pc__banner__btn-accept,' +
                  '#shopify-pc__banner__btn-decline,' +
                  '#shopify-pc__prefs__header-accept,' +
                  '#shopify-pc__prefs__header-decline,' +
                  '#shopify-pc__prefs__header-save'
              );
            if (btn) {
              consentFinalized = true;
              setOverlay(false);
              setTimeout(function () {
                setOverlay(false);
              }, 0);
              requestAnimationFrame(function () {
                setOverlay(false);
              });
            }
          },
          true
        );

        var mo = new MutationObserver(function () {
          if (consentFinalized) return;
          if (moRafScheduled) return;
          moRafScheduled = true;
          requestAnimationFrame(function () {
            moRafScheduled = false;
            recompute();
          });
        });

        mo.observe(document.body, { childList: true, subtree: true });

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', handleInitial);
        } else {
          handleInitial();
        }
      })();
    </script>
    <script>
      (function () {
        var TOP = 2147483000;
        var BELOW_TOP = TOP - 1;

        function demoteFormEmbed() {
          document.querySelectorAll('form-embed').forEach(function(host){
            try {
              var sr = host.shadowRoot;
              if (!sr) return;
              var app = sr.querySelector('#app-embed');
              if (app) {
                app.style.zIndex = String(BELOW_TOP);
              }
            } catch(e){}
          });

          document.querySelectorAll('shop-discount-auth').forEach(function(host){
            try {
              var sr = host.shadowRoot;
              if (!sr) return;
              var ov = sr.querySelector('.sda-overlay');
              if (ov) {
                ov.style.zIndex = String(BELOW_TOP);
              }
            } catch(e){}
          });
        }

        demoteFormEmbed();
        new MutationObserver(function(){ demoteFormEmbed(); })
          .observe(document.documentElement, { childList: true, subtree: true });
      })();
    </script>
</body>
</html>
