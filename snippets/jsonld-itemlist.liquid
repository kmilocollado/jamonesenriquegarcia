<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    {% for p in collection.products %}
    {
      "@type": "ListItem",
      "position": {{ forloop.index }},
      "item": {
        "@type": "Product",
        "@id": {{ shop.url | append: p.url | json }},
        "name": {{ p.title | json }},
        {%- assign media_size = p.featured_media.preview_image.width | append: 'x' %}
        "image": {{ p.featured_image | img_url: media_size | prepend: "https:" | json }},
        "description": {{ p.description  | strip_html | json }},
        {% if p.variants.first.sku != blank %}
        "sku": {{ p.variants.first.sku | json }},
        {% endif %}
        "offers": {
          "@type": "Offer",
          "url": {{ shop.url | append: p.url | json }},
          "price": {{ p.price | divided_by: 100.0 | json }},
          "priceCurrency":{{ shop.currency | json }},
          "availability":"https://schema.org/{% if p.available %}InStock{% else %}OutOfStock{% endif %}"
        }
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>