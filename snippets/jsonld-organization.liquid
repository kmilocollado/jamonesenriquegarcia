<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": "{{ shop.name | escape }}",
    "url": {{ shop.url | json }}, 
    "logo": "https://cdn.shopify.com/s/files/1/0962/2162/6706/files/LOGOizquda_1_.pdf_3.jpg",
    "sameAs": [
        {% if settings.sm_instagram_link != blank -%}{{ settings.sm_instagram_link | json }}{% if settings.sm_facebook_link != blank -%},{% endif %}{% endif %}
