ht":"bold","text":"<p>Elaboramos ibéricos de forma artesanal desde 1920.<\/p>","button_link":"","button_text":""}},"image_and_text_QwLmMk":{"type":"image_and_text","settings":{"image":"shopify:\/\/shop_images\/ciclo-cerrado.png","grid_image_size":"natural","info_image_margin_bottom":20,"heading":"CICLO CERRADO","title_text_transform":"uppercase","heading_tag":"span","info_title_font_size":12,"info_title_font_weight":"bold","text":"<p>Ciclo controlado de producción y elaboración.<\/p>","button_link":"","button_text":""}},"image_and_text_MB3ymY":{"type":"image_and_text","settings":{"image":"shopify:\/\/shop_images\/village.png","grid_image_size":"square","info_image_margin_bottom":20,"heading":"DE SALAMANCA","title_text_transform":"uppercase","heading_tag":"span","info_title_font_size":12,"info_title_font_weight":"bold","text":"<p>Ibéricos elaborados en Valdecarros, corazón de la dehesa.<\/p>","button_link":"","button_text":""}},"image_and_text_wdxU8w":{"type":"image_and_text","settings":{"image":"shopify:\/\/shop_images\/pig_2.png","grid_image_size":"natural","info_image_margin_bottom":20,"heading":"CALIDAD","title_text_transform":"uppercase","heading_tag":"span","info_title_font_size":12,"info_title_font_weight":"bold","text":"<p>Calidad constante y certificada. Excelencia Garantizada.<\/p>","button_link":"","button_text":""}}},"block_order":["image_and_text_9JH7Gp","image_and_text_QwLmMk","image_and_text_MB3ymY","image_and_text_wdxU8w"],"custom_css":[],"settings":{"title":"","description":"","maximum_width":50,"override_border_radius":false,"buttons_style":"filled","override_button_colors":true,"button_background_color":"#ffffff","button_text_color":"#1a1a1a","hover_navigation_desktop":"left-and-right","columns_per_row":4,"vertical_alignment":"top","text_alignment":"center","text_alignment_mobile":"center","section_width":"full","section_padding_top":60,"section_padding_bottom":60,"colors":"accent"}},"rich_text_NaECrt":{"type":"rich-text","blocks":{"heading_FYxwKK":{"type":"heading","settings":{"heading":"Embutidos ibéricos, dos caracteres, infinitas posibilidades: guía para disfrutarlos","heading_tag":"h2","heading--text-size":24,"heading_bottom_spacing":20}},"richtext_bUUYwr":{"type":"richtext","settings":{"text":"<p>Cada uno de nuestros embutidos de bellota ibéricos representa una personalidad distinta, un carácter único diseñado para momentos diferentes. Te invitamos a descubrir sus matices para que disfrutes de una experiencia gastronómica completa.<\/p>","text_size":14,"text_bottom_spacing":0}}},"block_order":["heading_FYxwKK","richtext_bUUYwr"],"name":"t:sections.text--rich-text.presets.name","settings":{"section_width":"narrow","text_alignment_desktop":"center","text_alignment_mobile":"center","section_padding_top":60,"section_padding_bottom":30,"colors":"white"}},"image_with_text_xxFUaY":{"type":"image-with-text","name":"t:sections.image--image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/Embutidos.jpg","layout":"left","reverse_order_mobile":false,"subheading":"","title":"El chorizo de bellota ibérico: el alma de la fiesta","title_tag":"h3","text":"<ul><li><strong>Su carácter:<\/strong> intenso, alegre y rotundo. Su aroma a pimentón y adobo tradicional evoca celebración y tradición compartida.<\/li><li><strong>En boca:<\/strong> ofrece un sabor potente, jugoso y persistente, con un equilibrio perfecto entre el magro de bellota y el toque cálido de las especias.<\/li><li><strong>El momento ideal:<\/strong> es el protagonista indiscutible de un aperitivo con amigos, la estrella de un bocadillo gourmet o el toque de sabor que transforma un plato de legumbres. Marida a la perfección con vinos tintos con cuerpo y quesos curados.<\/li><\/ul>","text_alignment":"left","text_overlapping_image":false,"button_link":"","button_label":"","buttons_style":"filled","override_button_colors":false,"button_background_color":"#e68819","button_text_color":"#ffffff","secondary_button_link":"","secondary_button_label":"","secondary_buttons_style":"outlined","override_secondary_button_colors":false,"secondary_button_background_color":"#ffffff","secondary_button_text_color":"#000000","button_layout":"inline","button_spacing":10,"section-width":"full","section_padding_top":60,"section_padding_bottom":0,"colors":"light"}},"image_with_text_fp6mnP":{"type":"image-with-text","name":"t:sections.image--image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/salchichon-bellota-iberico-2.jpg","layout":"right","reverse_order_mobile":false,"subheading":"","title":"El salchichón de bellota ibérico: la expresión de la elegancia","title_tag":"h3","text":"<ul><li><strong>Su carácter:<\/strong> sutil, distinguido y complejo. Su perfume es más delicado, con notas de pimienta negra y los aromas de su larga curación en bodega.<\/li><li><strong>En boca:<\/strong> es pura finura. Su sabor es más suave al inicio, pero crece en el paladar, dejando un regusto largo, noble y lleno de matices a frutos secos.<\/li><li><strong>El momento ideal:<\/strong> perfecto para una tabla de degustación, para acompañar con vinos blancos secos o tintos ligeros, o para un disfrute personal y sosegado. Combina maravillosamente con pan de cristal, higos frescos o almendras.<\/li><\/ul>","text_alignment":"left","text_overlapping_image":false,"button_link":"","button_label":"","buttons_style":"filled","override_button_colors":false,"button_background_color":"#e68819","button_text_color":"#ffffff","secondary_button_link":"","secondary_button_label":"","secondary_buttons_style":"outlined","override_secondary_button_colors":false,"secondary_button_background_color":"#ffffff","secondary_button_text_color":"#000000","button_layout":"inline","button_spacing":10,"section-width":"full","section_padding_top":0,"section_padding_bottom":60,"colors":"light"}},"rich_text_FkGBXW":{"type":"rich-text","blocks":{"heading_TPix9D":{"type":"heading","settings":{"heading":"Tanto si prefieres la intensidad vibrante del chorizo como la elegancia sutil del salchichón, con nuestros embutidos de bellota ibéricos te aseguras un producto de calidad excepcional, fiel reflejo de nuestra tierra y nuestra historia.","heading_tag":"span","heading--text-size":20,"heading_bottom_spacing":20}}},"block_order":["heading_TPix9D"],"name":"t:sections.text--rich-text.presets.name","settings":{"section_width":"narrow","text_alignment_desktop":"center","text_alignment_mobile":"center","section_padding_top":0,"section_padding_bottom":30,"colors":"white"}},"collection_list_wxCnwe":{"type":"collection-list","blocks":{"featured_collection_NjgRkq":{"type":"featured_collection","settings":{"collection":"jamones-ibericos","collection_img":"shopify:\/\/shop_images\/JAMONES_Homepage_5.jpg","custom_title":"","subheading":"","overlay-btn-text":"","show-gradient-overlay":false,"overlay_font_color":"#ffffff","overlay_color":"#1a1a1a"}},"featured_collection_PABrf9":{"type":"featured_collection","settings":{"collection":"paletas-ibericas","collection_img":"shopify:\/\/shop_images\/PALETAS_Homepage_1.jpg","custom_title":"","subheading":"","overlay-btn-text":"","show-gradient-overlay":false,"overlay_font_color":"#ffffff","overlay_color":"#1a1a1a"}},"featured_collection_UEC48g":{"type":"featured_collection","settings":{"collection":"lomos-ibericos","collection_img":"shopify:\/\/shop_images\/Diseno_sin_titulo_31.jpg","custom_title":"","subheading":"","overlay-btn-text":"","show-gradient-overlay":false,"overlay_font_color":"#ffffff","overlay_color":"#1a1a1a"}},"featured_collection_NnMVr6":{"type":"featured_collection","settings":{"collection":"carnes-ibericas","collection_img":"shopify:\/\/shop_images\/carnes-ibericas.jpg","custom_title":"Carnes ibéricas","subheading":"","overlay-btn-text":"","show-gradient-overlay":false,"overlay_font_color":"#ffffff","overlay_color":"#1a1a1a"}}},"block_order":["featured_collection_NjgRkq","featured_collection_PABrf9","featured_collection_UEC48g","featured_collection_NnMVr6"],"name":"t:sections.collection--collection-list.presets.name","settings":{"title":"También te recomendamos...","description":"","items-per-row":4,"content-position":"below-image","buttons_style":"filled","override_button_colors":false,"button_background_color":"#e68819","button_text_color":"#ffffff","section-width":"full","section_padding_top":60,"section_padding_bottom":60,"remove-spacing":false,"collection_title_font_size":12,"mobile_items_per_row":"2","collection_title_uppercase":true,"collection_title_bold":true,"colors":"light"}},"accordion_YtERKW":{"type":"accordion","blocks":{"tab_content_t3FqAG":{"type":"tab_content","settings":{"question":"¿Cómo debo preparar la pieza de embutido de bellota antes de consumirla?","heading_tag":"h3","heading_weight":"bold","open_by_default":false,"text":"<p>Para disfrutar plenamente de la pieza de embutido de bellota, sácala del envase al vacío al menos 15 minutos antes de empezar a cortarla. Esto permite que el producto se oxigene y que sus aromas y sabores se expresen con toda su intensidad. Comienza haciendo un corte limpio y desecha la primera rodaja para apreciar la máxima frescura en el resto.<\/p>","page":""}},"tab_content_pTPDmR":{"type":"tab_content","settings":{"question":"¿La longaniza es un chorizo o un salchichón?","heading_tag":"h3","heading_weight":"bold","open_by_default":false,"text":"<p>La longaniza es un formato más pequeño del chorizo o salchichón convencional o tipo vela. La longaniza se caracteriza por su forma de herradura, curvada y con un diámetro más pequeño, en lugar de la forma longitudinal del chorizo o salchichón. Por eso, la textura de la carne en la longaniza ibérica es más fina y jugosa.<\/p>","page":""}},"tab_content_8FNJGK":{"type":"tab_content","settings":{"question":"¿Cómo es el proceso de curación de los embutidos ibéricos y por qué es tan importante?","heading_tag":"h3","heading_weight":"bold","open_by_default":false,"text":"<p>La curación de los embutidos ibéricos es la etapa donde cada pieza desarrolla su carácter. Nuestro proceso es totalmente natural y se realiza en secaderos y bodegas centenarias aquí en Salamanca, donde las condiciones climáticas son idóneas. Durante varios meses, chorizos y salchichones de bellota reposan lentamente, sin prisas, permitiendo que el aire frío y seco del invierno y el calor del verano actúen sobre ellas. Este proceso de curación pausado es fundamental para que las piezas de embutido pierdan humedad, concentre sus sabores, desarrolle sus complejos aromas y alcance esa textura firme y perfecta que lo caracteriza.<\/p>","page":""}}},"block_order":["tab_content_t3FqAG","tab_content_pTPDmR","tab_content_8FNJGK"],"settings":{"title":"Preguntas frecuentes sobre embutidos de bellota ibéricos","description":"","faq_icon":"caret","section_width":"narrow","section_padding_top":60,"section_padding_bottom":60,"colors":"white"}}},"order":["collection-header-spotlight","rich_text_TkCpjb","product-grid","template_product_info_columns_iA6HkL","rich_text_NaECrt","image_with_text_xxFUaY","image_with_text_fp6mnP","rich_text_FkGBXW","collection_list_wxCnwe","accordion_YtERKW"]}